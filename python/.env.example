# ──────────────────────────────────────────────────────────────────────────────
# Alfanumrik AI Services — environment configuration.
#
# Copy to `python/.env` and fill in for local dev. None of these are required
# for `pytest` (providers + Supabase are mocked there). Required at runtime
# are flagged ``[required]``; flagged ``[required @ readyz]`` are checked by
# /readyz so the service can start without them but won't pass readiness.
# ──────────────────────────────────────────────────────────────────────────────

# Deployment environment. One of: production | staging | local. Default: local.
# Used by feature-flag lookups and structured logs.
ENVIRONMENT=local

# ─── Supabase (writes telemetry rows) ─────────────────────────────────────────
# [required @ readyz] — service-role client used to write mol_request_logs.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...your_service_role_key
# Required JWT audience. Supabase user access tokens use "authenticated".
# Change only if the Supabase project's Auth audience is deliberately custom.
SUPABASE_JWT_AUDIENCE=authenticated

# ─── Provider API keys (at least one required @ readyz) ───────────────────────
# Anthropic Claude. Used for: reasoning, doubt_solving pass-1, evaluation,
# ocr_extraction, and the fallback rung for OpenAI primary tasks.
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI. Used for: explanation, concept_explanation, step_by_step,
# quiz_generation (primary when ff_mol_openai_default is ON), and
# doubt_solving simplify pass. Also: Whisper STT for /v1/voice/transcribe.
OPENAI_API_KEY=sk-proj-...

# ─── Azure Cognitive Services Speech (Voice 1b — Indian-accent TTS) ───────────
# Provision in Central India region (Cloud Run is asia-south1/Mumbai so
# co-locating cuts ~30ms off the round-trip). Recommended resource name:
# alfanumrik-speech-prod. Get the key from the Azure portal → Keys & Endpoint.
#
# Free tier: 500K neural characters/month. Beyond that: $16 per 1M chars
# (~₹1.33 per 1000 chars at USD_TO_INR=83). The org-level daily budget
# guard at /v1/voice/synthesize caps runaway spend.
#
# Optional — empty key disables the /v1/voice/synthesize endpoint (returns
# 503 SERVICE_MISCONFIGURED per request). Service still BOOTS without it.
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=centralindia

# ─── Observability ────────────────────────────────────────────────────────────
# Sentry DSN. Optional — empty disables Sentry.
SENTRY_DSN=

# stdlib log level: DEBUG | INFO | WARNING | ERROR | CRITICAL. Default: INFO.
LOG_LEVEL=INFO

# ─── HTTP layer ───────────────────────────────────────────────────────────────
# Comma-separated origins for CORS. Production should NOT include "*".
ALLOWED_ORIGINS=http://localhost:3000,https://alfanumrik.com,https://staging.alfanumrik.com

# Port uvicorn binds to. Cloud Run convention is 8080.
PORT=8080

# ─── Currency conversion (mirrors USD_TO_INR in TS telemetry) ─────────────────
# Default 83 matches supabase/functions/_shared/mol/telemetry.ts; only change
# both files together — the row shape (`inr_cost`) MUST match across runtimes
# so the existing super-admin dashboard keeps working after cutover.
USD_TO_INR=83
