# Python build artefacts (byte-compiled / optimized / shared libs).
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution / packaging — generated by setuptools/build.
build/
dist/
*.egg-info/
*.egg
.eggs/
wheels/
develop-eggs/
downloads/
parts/
sdist/
var/

# Virtual environments. .venv is the project default (per pyproject); the
# others are common conventions we want to ignore in case someone uses
# `python -m venv venv` out of habit.
.venv/
venv/
ENV/
env/

# Test / coverage / type-check caches. The root .gitignore covers TS test
# artefacts (test-results/, playwright-report/, coverage/) but not these.
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.hypothesis/
coverage.xml
*.cover

# IDE / editor. Keep .vscode/extensions.json checkable-in so anyone can
# suggest extensions without polluting per-user settings.
.idea/
.vscode/*
!.vscode/extensions.json

# Local env files — never committed. Use .env.example as the template.
.env
.env.local
.env.*.local

# Jupyter notebook checkpoints (precautionary — no notebooks shipped today).
.ipynb_checkpoints/

# Python i18n compiled translations (convention; not used today).
*.mo
*.pot
