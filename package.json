{
  "name": "alfanumrik-frontend",
  "version": "2.0.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0 <23.0.0"
  },
  "scripts": {
    "dev": "next dev --webpack",
    "build": "node scripts/auth-guard.js && next build",
    "start": "next start",
    "lint": "eslint src/ --ext .ts,.tsx",
    "lint:migrations": "node scripts/lint-migrations.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "cross-env RUN_INTEGRATION_TESTS=1 vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "analyze": "cross-env ANALYZE=true next build",
    "check:bundle-size": "node scripts/check-bundle-size.mjs",
    "check:peer-deps": "node scripts/check-peer-deps.js",
    "check:config-parity": "bash scripts/check-config-parity.sh",
    "lint:ai-boundary": "bash scripts/check-config-parity.sh && eslint --config .eslintrc.ai-boundary.json --ext .ts,.tsx src supabase/functions",
    "test:coverage": "vitest run --coverage",
    "type-check": "tsc --noEmit",
    "supabase:gen-types": "node scripts/gen-supabase-types.mjs",
    "supabase:check-types": "node scripts/gen-supabase-types.mjs --check",
    "gen:openapi": "node scripts/gen-openapi.mjs",
    "gen:openapi:check": "node scripts/gen-openapi.mjs --check",
    "gen:dart": "openapi-generator-cli generate",
    "eval:rag": "npx tsx scripts/rag-eval.mjs",
    "eval:rag:check": "RAG_EVAL_THRESHOLD=0.80 npx tsx scripts/rag-eval.mjs",
    "eval:tenant-isolation": "npx tsx eval/tenant-isolation/run.ts",
    "eval:tenant-isolation:baseline": "npx tsx eval/tenant-isolation/run.ts --regenerate-baseline",
    "eval:unit-tests": "npx tsx eval/unit-tests/run.ts",
    "eval:type-check": "npx tsx eval/type-check/run.ts",
    "eval:lint": "npx tsx eval/lint/run.ts",
    "mesh:tick": "npx tsx agents/runtime/tick.ts",
    "forensic:quiz": "npx tsx scripts/forensic-quiz-lookup.ts",
    "retroactive-scan": "npx tsx scripts/retroactive-oracle-scan.ts",
    "smoke:agent": "npx tsx scripts/smoke-agent.ts",
    "flags:check": "npx tsx scripts/sync-production-flags.ts --check",
    "flags:sync": "npx tsx scripts/sync-production-flags.ts --apply",
    "flags:reset": "npx tsx scripts/sync-production-flags.ts --reset --force"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/core": "^2.6.1",
    "@opentelemetry/instrumentation": "^0.217.0",
    "@opentelemetry/sdk-trace-base": "^2.7.1",
    "@sentry/nextjs": "^10.53.1",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.105.4",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "canvas-confetti": "^1.9.4",
    "clsx": "^2.1.1",
    "katex": "^0.16.45",
    "next": "^16.2.6",
    "pdf-parse": "^2.4.5",
    "posthog-js": "^1.372.1",
    "posthog-node": "^5.33.4",
    "prom-client": "^15.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "rehype-katex": "^7.0.1",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "swr": "^2.4.1",
    "tailwind-merge": "^2.5.2",
    "zod": "^4.3.6"
  },
  "browserslist": [
    "Chrome >= 90",
    "Firefox >= 90",
    "Safari >= 14",
    "Edge >= 90",
    "iOS >= 14",
    "ChromeAndroid >= 90",
    "not dead",
    "not IE 11",
    "not op_mini all"
  ],
  "devDependencies": {
    "@asteasolutions/zod-to-openapi": "^8.5.0",
    "@next/bundle-analyzer": "^16.2.6",
    "@openapitools/openapi-generator-cli": "^2.34.0",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^25.8.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.6",
    "autoprefixer": "^10.5.0",
    "cross-env": "^10.1.0",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.35",
    "eslint-plugin-alfanumrik": "file:./eslint-plugin-alfanumrik",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.38",
    "puppeteer": "^25.0.4",
    "tailwindcss": "^3.4.4",
    "tsx": "^4.22.4",
    "typescript": "^5.4.5",
    "vitest": "^4.1.8"
  }
}
