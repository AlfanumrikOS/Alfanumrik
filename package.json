{
  "name": "alfanumrik-workspace",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "eslint-plugin-alfanumrik"
  ],
  "scripts": {
    "dev": "npm run dev -w apps/host",
    "build": "npm run build -w apps/host",
    "vercel-build": "NODE_OPTIONS=--max-old-space-size=4096 npm run build -w apps/host && node -e \"require('fs').cpSync('apps/host/.next', '.next', {recursive: true})\"",
    "check:bundle-size": "node scripts/check-bundle-size.mjs",
    "lint:migrations": "node scripts/lint-migrations.js",
    "lint": "npm run lint --workspaces --if-present",
    "type-check": "npm run type-check --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:integration": "npm run test:integration --workspaces --if-present",
    "supabase:gen-types": "npm run supabase:gen-types --workspaces --if-present",
    "supabase:check-types": "npm run supabase:check-types --workspaces --if-present",
    "gen:openapi": "node scripts/gen-openapi.mjs",
    "gen:openapi:check": "node scripts/gen-openapi.mjs --check",
    "eval:teacher:harness": "npm run eval:teacher:harness -w apps/host --"
  }
}
