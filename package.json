{
  "name": "alfanumrik-frontend",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "node scripts/auth-guard.js && next build",
    "start": "next start",
    "lint": "eslint src/ --ext .ts,.tsx",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "cross-env RUN_INTEGRATION_TESTS=1 vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "analyze": "cross-env ANALYZE=true next build",
    "check:bundle-size": "node scripts/check-bundle-size.mjs",
    "check:config-parity": "bash scripts/check-config-parity.sh",
    "lint:ai-boundary": "bash scripts/check-config-parity.sh && eslint --config .eslintrc.ai-boundary.json --ext .ts,.tsx src supabase/functions",
    "test:coverage": "vitest run --coverage",
    "type-check": "tsc --noEmit",
    "supabase:gen-types": "node scripts/gen-supabase-types.mjs",
    "supabase:check-types": "node scripts/gen-supabase-types.mjs --check"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/core": "^2.6.1",
    "@opentelemetry/instrumentation": "^0.214.0",
    "@opentelemetry/sdk-trace-base": "^2.6.1",
    "@sentry/nextjs": "^10.45.0",
    "@splinetool/react-spline": "^2.2.6",
    "@splinetool/runtime": "^1.9.27",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.49.1",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "canvas-confetti": "^1.9.4",
    "clsx": "^2.1.1",
    "framer-motion": "^11.3.19",
    "katex": "^0.16.45",
    "next": "^16.2.1",
    "pdf-parse": "^2.4.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "swr": "^2.4.1",
    "tailwind-merge": "^2.5.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.1",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^20.14.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.2",
    "autoprefixer": "^10.4.19",
    "cross-env": "^10.1.0",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.35",
    "eslint-plugin-alfanumrik": "file:./eslint-plugin-alfanumrik",
    "jsdom": "^29.0.1",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.4.5",
    "vitest": "^4.1.0"
  }
}
