{
  "framework": "nextjs",
  "regions": ["bom1"],
  "functions": {
    "src/app/api/cron/**/*.ts": {
      "maxDuration": 60
    },
    "src/app/api/**/*.ts": {
      "maxDuration": 30
    },
    "src/app/auth/**/*.ts": {
      "maxDuration": 30
    },
    "src/app/**/*.tsx": {
      "maxDuration": 15
    }
  },
  "crons": [
    {
      "path": "/api/cron/school-operations",
      "schedule": "0 2 * * *"
    }
  ],
  "cleanUrls": true,
  "trailingSlash": false
}
