{
  "$schema-comment": "D6 launch-readiness: /api/cron/daily-cron at 30 2 * * * is the CANONICAL daily-cron runner. The pg_cron job 'alfanumrik-daily-cron' (legacy 18:30 UTC schedule) is DISABLED via supabase migration 20260505100000_disable_pg_cron_daily_in_favor_of_vercel.sql to prevent duplicate parent_digest notifications. Do NOT re-enable pg_cron without first removing this Vercel entry.",
  "framework": "nextjs",
  "regions": ["bom1"],
  "functions": {
    "src/app/api/cron/daily-cron/route.ts": {
      "maxDuration": 300
    },
    "src/app/api/cron/irt-calibrate/route.ts": {
      "maxDuration": 300
    },
    "src/app/api/cron/**/*.ts": {
      "maxDuration": 60
    },
    "src/app/api/**/*.ts": {
      "maxDuration": 30
    },
    "src/app/auth/**/*.ts": {
      "maxDuration": 30
    },
    "src/app/**/*.tsx": {
      "maxDuration": 15
    }
  },
  "crons": [
    {
      "path": "/api/cron/school-operations",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/daily-cron",
      "schedule": "30 2 * * *"
    },
    {
      "path": "/api/cron/irt-calibrate",
      "schedule": "50 2 * * *"
    },
    {
      "path": "/api/cron/reconcile-payments",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/expired-subscriptions",
      "schedule": "15 */6 * * *"
    },
    {
      "path": "/api/cron/account-purge",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/pre-debit-notice",
      "schedule": "0 */6 * * *"
    }
  ],
  "cleanUrls": true,
  "trailingSlash": false
}
