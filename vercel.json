{
  "framework": "nextjs",
  "regions": ["bom1"],
  "functions": {
    "src/app/api/cron/daily-cron/route.ts": {
      "maxDuration": 300
    },
    "src/app/api/cron/irt-calibrate/route.ts": {
      "maxDuration": 300
    },
    "src/app/api/cron/**/*.ts": {
      "maxDuration": 60
    },
    "src/app/api/**/*.ts": {
      "maxDuration": 30
    },
    "src/app/auth/**/*.ts": {
      "maxDuration": 30
    },
    "src/app/**/*.tsx": {
      "maxDuration": 15
    }
  },
  "crons": [
    {
      "path": "/api/cron/school-operations",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/daily-cron",
      "schedule": "30 2 * * *"
    },
    {
      "path": "/api/cron/irt-calibrate",
      "schedule": "50 2 * * *"
    },
    {
      "path": "/api/cron/reconcile-payments",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/expired-subscriptions",
      "schedule": "15 */6 * * *"
    }
  ],
  "cleanUrls": true,
  "trailingSlash": false
}
