{
  "$schema": "./node_modules/@openapitools/openapi-generator-cli/config.schema.json",
  "spaces": 2,
  "generator-cli": {
    "version": "7.11.0",
    "generators": {
      "v2-dart": {
        "generatorName": "dart-dio",
        "inputSpec": "openapi/v2.json",
        "output": "mobile/lib/api/v2",
        "additionalProperties": {
          "pubName": "alfanumrik_api_v2",
          "pubLibrary": "alfanumrik_api_v2.api",
          "pubVersion": "2.0.0",
          "pubDescription": "Generated Dart client for the Alfanumrik /v2 API. DO NOT EDIT BY HAND — regenerate via `npm run gen:dart`.",
          "serializationLibrary": "built_value",
          "nullableFields": true
        }
      }
    }
  }
}
