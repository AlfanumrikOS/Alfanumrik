# Fastlane Appfile — Alfanumrik Android (Play Store publishing).
#
# json_key_file: path to the Google Play service-account JSON used by the
# Play Developer API. CI writes the secret to a file and exports its path as
# PLAY_SERVICE_ACCOUNT_JSON_PATH; locally it defaults to play-service-account.json
# (gitignored). NEVER commit the JSON.
json_key_file(ENV["PLAY_SERVICE_ACCOUNT_JSON_PATH"] || "play-service-account.json")

# Application id as registered in the Play Console. Matches applicationId /
# namespace in android/app/build.gradle.
package_name("com.alfanumrik.student")
