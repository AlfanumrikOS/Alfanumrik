# ══════════════════════════════════════════════════════════════════════════════
# ALFANUMRIK — Environment Variables (AUTHORITATIVE TEMPLATE)
# ══════════════════════════════════════════════════════════════════════════════
# Copy this file to `.env.local` and fill in real values for local development.
# For production, set each variable in the Vercel project settings.
# Edge Function variables go into Supabase Dashboard → Edge Functions → Secrets.
# See ENVIRONMENT_SETUP.md for the full operator guide.
#
# Legend:
#   [required]  — app will fail without this
#   [optional]  — feature degrades gracefully if unset
#   [public]    — exposed to client bundle (NEXT_PUBLIC_ prefix — never secrets)
#   [server]    — server-only (Next.js API routes, middleware)
#   [edge]      — Supabase Edge Function secret (set via `supabase secrets set` or Dashboard)
#   [auto]      — injected automatically by Vercel / Next.js — DO NOT set manually
# ══════════════════════════════════════════════════════════════════════════════


# ─────────────────────────────────────────────────────────────────────────────
# [APP] Application identity
# ─────────────────────────────────────────────────────────────────────────────

# [public][optional] Public-facing app URL. Used by super-admin improvement
# routes to build staging deployment URLs.
# NEXT_PUBLIC_APP_URL=https://alfanumrik.com

# [edge][required-in-prod] Production site URL consumed by send-auth-email
# when building email confirmation links. Falls back to https://alfanumrik.com
# if unset, but you MUST set this for preview/staging Edge Function deploys.
# SITE_URL=https://alfanumrik.com


# ─────────────────────────────────────────────────────────────────────────────
# [SUPABASE] Database, auth, storage, Edge Functions
# ─────────────────────────────────────────────────────────────────────────────

# [public][required] Your Supabase project URL.
# Get from: Supabase Dashboard → Project Settings → API → Project URL.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# [public][required] Anonymous API key (safe for client — respects RLS).
# Get from: Supabase Dashboard → Project Settings → API → anon public key.
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...your-anon-key

# [server][required] Service-role key (BYPASSES RLS — server-only!).
# NEVER prefix with NEXT_PUBLIC_. NEVER commit. NEVER send to clients.
# Get from: Supabase Dashboard → Project Settings → API → service_role secret.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...your-service-role-key


# ─────────────────────────────────────────────────────────────────────────────
# [ANTHROPIC] Claude AI — powers Foxy tutor, quiz generator, cme-engine
# ─────────────────────────────────────────────────────────────────────────────

# [server][required-for-ai] Anthropic API key. Used by:
#   • Next.js route  /api/foxy
#   • Edge Functions: foxy-tutor, ncert-solver, quiz-generator{,-v2},
#                     cme-engine, generate-answers, generate-concepts,
#                     bulk-question-gen, extract-*, parent-report-generator,
#                     daily-cron, scan-ocr, ncert-question-engine
# Set in BOTH Vercel (Next.js) AND Supabase Edge Function secrets.
ANTHROPIC_API_KEY=sk-ant-api03-...your-anthropic-key


# ─────────────────────────────────────────────────────────────────────────────
# [VOYAGE] Voyage AI embeddings + reranking — powers RAG
# ─────────────────────────────────────────────────────────────────────────────

# [server][required-for-rag] Voyage API key. Used for embeddings (voyage-3)
# and reranking. Primary embedding provider.
# Set in BOTH Vercel AND Supabase Edge Function secrets.
VOYAGE_API_KEY=pa-...your-voyage-key

# [edge][optional] OpenAI fallback for embeddings (used only if Voyage fails).
# OPENAI_API_KEY=sk-...your-openai-key


# ─────────────────────────────────────────────────────────────────────────────
# [AI] Feature flags for AI layer (optional — all default to ON)
# ─────────────────────────────────────────────────────────────────────────────

# Set to "false" to disable; any other value (or unset) keeps default ON.
# AI_ENABLE_INTENT_ROUTER=true
# AI_ENABLE_OUTPUT_VALIDATION=true
# AI_ENABLE_TRACING=true


# ─────────────────────────────────────────────────────────────────────────────
# [MAILGUN] Transactional email — Edge Functions only
# ─────────────────────────────────────────────────────────────────────────────
# These are EDGE FUNCTION SECRETS, not Vercel env vars.
# Set via: supabase secrets set MAILGUN_API_KEY=key-...
# Or via: Supabase Dashboard → Edge Functions → Secrets.

# [edge][required-for-email] Mailgun API key. Used by send-auth-email (P15!)
# and send-welcome-email.
# MAILGUN_API_KEY=key-xxxxxxxxxxxxxxxxxxxxx

# [edge][required-for-email] Mailgun sending domain (must be verified in Mailgun).
# MAILGUN_DOMAIN=alfanumrik.com

# [edge][required-for-auth-email] Supabase Auth webhook secret (format:
# v1,whsec_... or whsec_...). Generated when you register the Send Email hook in
# Supabase Dashboard → Authentication → Hooks. Used by standardwebhooks to
# verify that Supabase is the caller.
# SEND_EMAIL_HOOK_SECRET=v1,whsec_xxxxxxxxxxxxxxxxxxxxx


# ─────────────────────────────────────────────────────────────────────────────
# [RAZORPAY] Payment gateway (INR subscriptions + one-time)
# ─────────────────────────────────────────────────────────────────────────────
# Get keys from: https://dashboard.razorpay.com/app/keys
# For test mode, use rzp_test_... keys; for prod, use rzp_live_... keys.

# [server][required-for-payments] Razorpay API key ID (public part — but we
# keep it server-only so it's never in the client bundle).
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx

# [server][required-for-payments] Razorpay API secret. NEVER commit.
RAZORPAY_KEY_SECRET=your-razorpay-secret

# [server][required-for-payments] Webhook signing secret. Required to
# verify Razorpay webhook payloads per P11. Set this in BOTH the Razorpay
# dashboard webhook config AND as a Vercel env var.
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret


# ─────────────────────────────────────────────────────────────────────────────
# [REDIS] Upstash Redis — distributed rate limiting
# ─────────────────────────────────────────────────────────────────────────────
# Optional but STRONGLY RECOMMENDED in production. Without Redis, rate limits
# fall back to an in-memory Map per Vercel instance (each cold start resets
# counters; limits are not enforced across instances).
# Get free tier from: https://console.upstash.com

# [server][optional] Upstash Redis REST URL.
# UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io

# [server][optional] Upstash Redis REST token.
# UPSTASH_REDIS_REST_TOKEN=your-upstash-token


# ─────────────────────────────────────────────────────────────────────────────
# [SECURITY] Admin / cron / ingestion secrets
# ─────────────────────────────────────────────────────────────────────────────

# [server][required-for-admin] Secret that guards /internal/admin routes.
# Checked by admin-auth.ts and proxy.ts. Use a long random string.
SUPER_ADMIN_SECRET=generate-a-long-random-string-here

# [server][required-for-cron] Shared secret for cron endpoints (Vercel Cron).
# Used by /api/cron/school-operations, /api/cron/evaluate-alerts, and the
# daily-cron Edge Function. Vercel Cron sends it as x-cron-secret header.
# CRON_SECRET=generate-another-long-random-string

# [edge][required-for-ingestion] Key that gates admin-triggered Edge Functions:
# embed-*, generate-*, extract-*. Not for end-user traffic.
# Set via Supabase Edge Function secrets.
# ADMIN_API_KEY=generate-a-third-long-random-string


# ─────────────────────────────────────────────────────────────────────────────
# [MONITORING] Sentry error tracking (optional)
# ─────────────────────────────────────────────────────────────────────────────
# If you skip these, errors log to console instead. Sentry is only wrapped
# when NODE_ENV=production or CI=true (see next.config.js).

# [public][optional] Sentry DSN for client/server/edge runtimes.
# NEXT_PUBLIC_SENTRY_DSN=https://xxxxxxx@o123456.ingest.sentry.io/123456

# [server][optional] Sentry org slug (for source map uploads at build time).
# SENTRY_ORG=your-org

# [server][optional] Sentry project slug.
# SENTRY_PROJECT=alfanumrik


# ─────────────────────────────────────────────────────────────────────────────
# [INTEGRATIONS] Optional third-party services (Edge Function scope)
# ─────────────────────────────────────────────────────────────────────────────

# [edge][optional] WhatsApp Cloud API — used by whatsapp-notify.
# WHATSAPP_TOKEN=your-whatsapp-token
# WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id

# [edge][optional] OCR — used by scan-ocr. Defaults to ocr.space free-tier
# (OCR_SPACE_API_KEY=helloworld) if unset. Upgrade both for better quality.
# GOOGLE_VISION_API_KEY=your-gcp-vision-key
# OCR_SPACE_API_KEY=your-ocr-space-key

# [edge][optional] Environment marker read by Edge Function CORS to permit
# localhost. Set to "production" on deploy; leave unset locally.
# ENVIRONMENT=production


# ─────────────────────────────────────────────────────────────────────────────
# [AUTO] Vercel-injected — DO NOT SET MANUALLY
# ─────────────────────────────────────────────────────────────────────────────
# These are set automatically by the Vercel runtime and are only listed here
# for reference so nobody sets them by hand.
#
#   NODE_ENV                         (Next.js — development/production)
#   NEXT_PHASE                       (Next.js — build vs runtime)
#   VERCEL, VERCEL_ENV, VERCEL_URL   (Vercel — deployment metadata)
#   VERCEL_REGION, VERCEL_DEPLOYMENT_ID
#   VERCEL_GIT_COMMIT_SHA, VERCEL_GIT_COMMIT_REF,
#   VERCEL_GIT_COMMIT_MESSAGE, VERCEL_GIT_COMMIT_AUTHOR_LOGIN
#   NEXT_PUBLIC_VERCEL_GIT_COMMIT_SHA (Vercel — publicized commit SHA)
#   CI                               (GitHub Actions runner)
#   ANALYZE                          (set by `npm run analyze` script)
