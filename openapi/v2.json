            "example": "2026-06-06T09:00:00.000Z",
            "type": "string"
          },
          "schemaVersion": {
            "enum": [
              1
            ],
            "type": "number"
          }
        },
        "required": [
          "schemaVersion",
          "resolvedAt",
          "primary",
          "queue",
          "meta"
        ],
        "type": "object"
      },
      "TodayResponseMeta": {
        "properties": {
          "branch": {
            "example": "review_due_cards",
            "type": "string"
          },
          "dueReviewCount": {
            "example": 7,
            "minimum": 0,
            "type": "integer"
          },
          "masterySubjectCount": {
            "example": 3,
            "minimum": 0,
            "type": "integer"
          }
        },
        "required": [
          "branch",
          "masterySubjectCount",
          "dueReviewCount"
        ],
        "type": "object"
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "bearerFormat": "JWT",
        "description": "Supabase access-token JWT (mobile clients).",
        "scheme": "bearer",
        "type": "http"
      },
      "cookieAuth": {
        "description": "Supabase session cookie (web clients).",
        "in": "cookie",
        "name": "sb-access-token",
        "type": "apiKey"
      }
    }
  },
  "info": {
    "description": "The Alfanumrik /v2 contract. Single source of truth: src/lib/api/v2/contract.ts (Zod). This document is generated by `npm run gen:openapi` and consumed by the Dart client codegen (`npm run gen:dart`). Do not edit by hand.",
    "title": "Alfanumrik /v2 API",
    "version": "2.0.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/v2/learn/concept": {
      "get": {
        "description": "Returns the ordered NCERT chapter prose (markdown + source attribution) for a subject + chapter. Reuses fetchChapterContent (rag_content_chunks read used by /learn). Requires study_plan.view.",
        "operationId": "getLearnConcept",
        "parameters": [
          {
            "in": "query",
            "name": "subject",
            "required": true,
            "schema": {
              "example": "science",
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "grade",
            "required": true,
            "schema": {
              "pattern": "^(6|7|8|9|10|11|12)$",
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "chapter",
            "required": true,
            "schema": {
              "example": 3,
              "exclusiveMinimum": 0,
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConceptResponse"
                }
              }
            },
            "description": "Concept content."
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Invalid query params."
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "No content for this chapter."
          },
          "500": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Unexpected server error."
          }
        },
        "security": [
          {
            "bearerAuth": []
          },
          {
            "cookieAuth": []
          }
        ],
        "summary": "Concept content for a subject + chapter",
        "tags": [
          "learn"
        ]
      }
    },
    "/v2/learn/curriculum": {
