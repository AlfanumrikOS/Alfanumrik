{
  "agent": "orchestrator",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/guard.sh",
            "timeout": 5000,
            "statusMessage": "Checking write permissions..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/review-chain.sh",
            "timeout": 5000,
            "statusMessage": "Checking review chain requirements..."
          }
        ]
      }
    ]
  }
}
